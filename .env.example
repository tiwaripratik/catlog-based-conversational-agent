# SHL Assessment Recommender — Environment Variables (Example)
# Copy to .env and fill in your values.

# ─── HuggingFace API ─────────────────────────────────────
HF_TOKEN=your_huggingface_api_token_here

# ─── PostgreSQL Database ─────────────────────────────────
DB_NAME=shl_recommender
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# For cloud deployment (overrides individual DB_* vars):
# DATABASE_URL=postgresql://user:password@host:port/dbname
